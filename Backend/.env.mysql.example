# Environment variables for MySQL configuration
# Copy these to your system environment variables or create a .env file

DB_ENGINE=django.db.backends.mysql
DB_NAME=precise_optics_db
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Other settings
SECRET_KEY=replace-with-generated-secret-key
DEBUG=False
ENVIRONMENT=production
ALLOWED_HOSTS=api.example.com,app.example.com