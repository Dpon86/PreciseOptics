{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^8.20.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^2.0.1",
    "date-fns": "^2.29.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.3.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:login": "playwright test --grep \"can login\" --headed --project=chromium",
    "test:auth": "playwright test e2e/auth.spec.js --headed --project=chromium",
    "test:patients": "playwright test e2e/patients.spec.js --headed --project=chromium",
    "test:consultations": "playwright test e2e/consultations.spec.js --headed --project=chromium",
    "test:medications": "playwright test e2e/medications.spec.js --headed --project=chromium",
    "test:eye-tests": "playwright test e2e/eye-tests.spec.js --headed --project=chromium",
    "test:treatments": "playwright test e2e/treatments.spec.js --headed --project=chromium",
    "test:dashboard": "playwright test e2e/dashboard-reports.spec.js --headed --project=chromium",
    "test:admin": "playwright test e2e/admin-system.spec.js --headed --project=chromium",
    "test:screenshots": "playwright test --grep \"User Manual\" --project=chromium",
    "test:report": "playwright show-report"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  }
}
