# PreciseOptics production environment template
# Copy to .env on the production host and replace all placeholder values.
# NEVER commit populated secrets.

# Core
SECRET_KEY=replace-with-generated-secret-key
DEBUG=False
ENVIRONMENT=production
ALLOWED_HOSTS=api.example.com,app.example.com

# Database (PostgreSQL recommended)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=precise_optics_db
DB_USER=precise_optics_user
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=300
DB_CONN_HEALTH_CHECKS=True

# Frontend/CORS
FRONTEND_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_ALL_ORIGINS=False

# Auth token expiry
TOKEN_EXPIRY_HOURS=24

# Email (password reset/notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=PreciseOptics <noreply@example.com>

# Error tracking (Sentry)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
APP_RELEASE=precise-optics-prod

# Backup / DR
BACKUP_DIR=/backups/preciseoptics
BACKUP_RETENTION_DAYS=2555
BACKUP_ENCRYPT=true
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-strong-passphrase
