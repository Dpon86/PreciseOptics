# PreciseOptics Backend - Environment Variables
# Copy this file to .env and fill in production values
# NEVER commit .env to version control

# =============================================================================
# Django Core
# =============================================================================
# Generate a new key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# REQUIRED — no default. The app will not start if this is not set.
SECRET_KEY=replace-with-strong-random-key

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts. NEVER include '*' in production.
ALLOWED_HOSTS=api.preciseoptics.com,www.preciseoptics.com

# Environment name: development | production
ENVIRONMENT=production

# =============================================================================
# Database (SQLite for dev, PostgreSQL/MySQL for production)
# =============================================================================
# Development (default - SQLite)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB connection reuse (seconds). Keep 0 for SQLite, use 300+ for production DBs.
DB_CONN_MAX_AGE=300
DB_CONN_HEALTH_CHECKS=True
# PostgreSQL SSL mode for production: require | verify-ca | verify-full
DB_SSLMODE=require

# Production (PostgreSQL) - uncomment and fill in
#DB_ENGINE=django.db.backends.postgresql
#DB_NAME=precise_optics_db
#DB_USER=precise_optics_user
#DB_PASSWORD=strong_password_here
#DB_HOST=localhost
#DB_PORT=5432

# Production (MySQL) - uncomment and fill in
#DB_ENGINE=django.db.backends.mysql
#DB_NAME=precise_optics_db
#DB_USER=precise_optics_user
#DB_PASSWORD=strong_password_here
#DB_HOST=localhost
#DB_PORT=3306

# =============================================================================
# Email (for password reset, notifications)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=PreciseOptics <noreply@example.com>

# =============================================================================
# Security (production only)
# =============================================================================
# HTTPS enforcement
#SECURE_SSL_REDIRECT=True
#SECURE_HSTS_SECONDS=31536000
#SECURE_HSTS_INCLUDE_SUBDOMAINS=True
#SECURE_HSTS_PRELOAD=True
#SESSION_COOKIE_SECURE=True
#CSRF_COOKIE_SECURE=True

# CORS (configure for your frontend domain in production)
# REQUIRED — no default. Must be the production frontend HTTPS URL.
CORS_ALLOWED_ORIGINS=https://app.preciseoptics.com
# Must be False in production
CORS_ALLOW_ALL_ORIGINS=False

# Frontend URL used in password reset emails
# REQUIRED — no default. Must be HTTPS in production.
FRONTEND_URL=https://app.preciseoptics.com

# =============================================================================
# Caching (Redis for production)
# =============================================================================
#CACHE_BACKEND=django_redis.cache.RedisCache
#CACHE_LOCATION=redis://127.0.0.1:6379/1

# =============================================================================
# Error Tracking (Sentry)
# =============================================================================
# Leave empty to disable. Set in production to enable alerting and tracing.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
APP_RELEASE=precise-optics-prod

# =============================================================================
# Backup & Disaster Recovery
# =============================================================================
# Backup script settings (used by scripts/backup_prod.sh)
BACKUP_DIR=/backups/preciseoptics
BACKUP_RETENTION_DAYS=2555
BACKUP_ENCRYPT=true
# Store securely in a secret manager for production
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-strong-passphrase

# =============================================================================
# File Storage
# =============================================================================
MEDIA_URL=/media/
STATIC_URL=/static/
# For production with S3:
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_STORAGE_BUCKET_NAME=
